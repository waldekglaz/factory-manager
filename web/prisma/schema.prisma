// Prisma schema for Stock Management & Production Planning
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── PARTS ───────────────────────────────────────────────────────────────────
model Part {
  id               Int     @id @default(autoincrement())
  name             String  @unique
  currentStock     Int     @default(0)
  minimumStock     Int?
  supplierLeadTime Int                    // fallback lead time (days)
  unit             String  @default("pcs")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productParts       ProductPart[]
  stockMovements     StockMovement[]
  orderParts         OrderPart[]
  supplierParts      SupplierPart[]
  purchaseOrderLines PurchaseOrderLine[]
  locationStocks     PartLocationStock[]
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────
model Product {
  id             Int    @id @default(autoincrement())
  name           String @unique
  dailyCapacity  Int    // units of this product that can be made per working day
  description    String @default("")
  finishedStock  Int    @default(0) // units ready to ship (warehouse stock)
  sellingPrice   Float?             // unit selling price (optional, used for invoices)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productParts           ProductPart[]
  orders                 Order[]
  finishedGoodsMovements FinishedGoodsMovement[]
  locationStocks         ProductLocationStock[]
}

// ─── BILL OF MATERIALS (BOM) ──────────────────────────────────────────────────
// Yield model: "materialQty units of material makes productsPerBatch products"
// Examples:
//   1 sheet of HPL  → makes 5 t700s : materialQty=1, productsPerBatch=5
//   4 black pins    → per t700       : materialQty=4, productsPerBatch=1
//   scrapFactor=0.05 → add 5% extra material to account for waste
model ProductPart {
  id               Int   @id @default(autoincrement())
  productId        Int
  partId           Int
  materialQty      Int   @default(1)
  productsPerBatch Int   @default(1)
  scrapFactor      Float @default(0) // 0.05 = 5% extra

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  part    Part    @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([productId, partId])
}

// ─── CUSTOMERS ────────────────────────────────────────────────────────────────
model Customer {
  id        Int    @id @default(autoincrement())
  name      String @unique
  email     String?
  phone     String?
  address   String?
  notes     String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]
}

// ─── ORDERS ───────────────────────────────────────────────────────────────────
model Order {
  id                  Int       @id @default(autoincrement())
  productId           Int
  customerId          Int?      // optional — internal orders have no customer
  quantity            Int
  desiredDeadline     DateTime?
  status              String    @default("planned") // planned | in_production | completed | cancelled
  productionStartDate DateTime?
  productionEndDate   DateTime?
  isOnTime            Boolean?
  fulfilledFromStock  Int       @default(0) // units covered by existing finished goods
  notes               String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product    Product     @relation(fields: [productId], references: [id])
  customer   Customer?   @relation(fields: [customerId], references: [id])
  orderParts OrderPart[]
}

// ─── ORDER PARTS ─────────────────────────────────────────────────────────────
// Snapshot of part requirements when the order was placed
model OrderPart {
  id              Int      @id @default(autoincrement())
  orderId         Int
  partId          Int
  quantityNeeded  Int
  quantityInStock Int
  quantityMissing Int
  availableDate   DateTime

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part  @relation(fields: [partId], references: [id])
}

// ─── STORAGE LOCATIONS ────────────────────────────────────────────────────────
// Physical places where materials and finished goods are stored.
// e.g. "Unit 1", "Warehouse B - Shelf 3", "Cold Storage"
model Location {
  id           Int     @id @default(autoincrement())
  name         String  @unique  // full name shown in UI
  code         String?          // short code e.g. "U1", "WH-B3"
  description  String  @default("")
  isActive     Boolean @default(true)
  isRemote     Boolean @default(false) // stock here needs transit time before it can be used
  deliveryDays Int?                    // calendar days to receive stock from this location

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partStocks             PartLocationStock[]
  productStocks          ProductLocationStock[]
  stockMovements         StockMovement[]
  finishedGoodsMovements FinishedGoodsMovement[]
}

// ─── PART STOCK PER LOCATION ─────────────────────────────────────────────────
// Tracks how many units of a part are stored in each location.
// Sum of all rows for a partId = Part.currentStock (for location-assigned stock).
// Any unassigned stock = Part.currentStock - sum(PartLocationStock for that part).
model PartLocationStock {
  id         Int @id @default(autoincrement())
  partId     Int
  locationId Int
  quantity   Int @default(0)

  part     Part     @relation(fields: [partId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([partId, locationId])
}

// ─── PRODUCT (FINISHED GOODS) STOCK PER LOCATION ─────────────────────────────
model ProductLocationStock {
  id         Int @id @default(autoincrement())
  productId  Int
  locationId Int
  quantity   Int @default(0)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([productId, locationId])
}

// ─── STOCK MOVEMENTS ─────────────────────────────────────────────────────────
model StockMovement {
  id         Int      @id @default(autoincrement())
  partId     Int
  locationId Int?     // which location was affected (null = unassigned)
  quantity   Int      // positive = added, negative = consumed
  reason     String
  createdAt  DateTime @default(now())

  part     Part      @relation(fields: [partId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
}

// ─── FINISHED GOODS MOVEMENTS ────────────────────────────────────────────────
model FinishedGoodsMovement {
  id         Int      @id @default(autoincrement())
  productId  Int
  locationId Int?     // which location was affected (null = unassigned)
  quantity   Int      // positive = added to stock, negative = reserved/shipped
  reason     String
  createdAt  DateTime @default(now())

  product  Product   @relation(fields: [productId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])
}

// ─── SUPPLIERS ────────────────────────────────────────────────────────────────
model Supplier {
  id              Int    @id @default(autoincrement())
  name            String @unique
  email           String?
  phone           String?
  defaultLeadTime Int    @default(7) // default days for any part from this supplier
  notes           String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplierParts  SupplierPart[]
  purchaseOrders PurchaseOrder[]
}

// ─── SUPPLIER PARTS ───────────────────────────────────────────────────────────
// Links a supplier to parts they supply, with optional cost and lead time override
model SupplierPart {
  id               Int    @id @default(autoincrement())
  supplierId       Int
  partId           Int
  unitCost         Float? // cost per unit from this supplier (optional)
  leadTimeOverride Int?   // overrides supplier.defaultLeadTime for this specific part

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  part     Part     @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@unique([supplierId, partId])
}

// ─── PURCHASE ORDERS ──────────────────────────────────────────────────────────
model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  supplierId   Int
  status       String    @default("sent") // draft | sent | partial | received | cancelled
  expectedDate DateTime?
  notes        String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplier Supplier          @relation(fields: [supplierId], references: [id])
  lines    PurchaseOrderLine[]
}

// ─── PURCHASE ORDER LINES ─────────────────────────────────────────────────────
model PurchaseOrderLine {
  id               Int @id @default(autoincrement())
  purchaseOrderId  Int
  partId           Int
  quantityOrdered  Int
  quantityReceived Int @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  part          Part          @relation(fields: [partId], references: [id])
}
